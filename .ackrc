--type-set=asciidoc:ext:asciidoc
--type-set=ebuild:ext:ebuild
--type-set=gettext:ext:po,pot
--type-set=kconfig:is:Kconfig

# Protobuf
--type-set=proto:ext:proto
--type-set=pbgen:match:/\.pb\.(cc|h|go)|_pb2.py$/

# Code composer
--type-set=ccspp:ext:pp

# ignore some files
--ignore-file=is:tags
--ignore-file=ext:a
--noccspp

--nopbgen
